<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <title>Todo List</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">
  <div class="container py-5">
    <h1 class="text-center mb-4">Todo List Abdellah</h1>
    <form action="/add" method="POST" class="row g-2 mb-4">
      <input name="task" placeholder="Titre de la tâche" required class="form-control">
      <input name="description" placeholder="Description" class="form-control">
      <select name="status" class="form-control">
        <option>À faire</option>
        <option>En cours</option>
        <option>Terminée</option>
      </select>
      <select name="priority" class="form-control">
        <option>Basse</option>
        <option selected>Moyenne</option>
        <option>Haute</option>
      </select>
      <input class="form-control" type="date" name="dueDate">
      <button class="btn btn-primary w-100">Ajouter</button>
    </form>

    <form class="row mb-3" method="GET">
      <div class="col-md-3">
        <select class="form-select" name="status" onchange="this.form.submit()">
          <option <%=selectedStatus==='Tous' ? 'selected' : '' %>>Tous</option>
          <option <%=selectedStatus==='À faire' ? 'selected' : '' %>>À faire</option>
          <option <%=selectedStatus==='En cours' ? 'selected' : '' %>>En cours</option>
          <option <%=selectedStatus==='Terminée' ? 'selected' : '' %>>Terminée</option>
        </select>
      </div>
      <div class="col-md-3">
        <select class="form-select" name="priority" onchange="this.form.submit()">
          <option <%=selectedPriority==='Toutes' ? 'selected' : '' %>>Toutes</option>
          <option <%=selectedPriority==='Basse' ? 'selected' : '' %>>Basse</option>
          <option <%=selectedPriority==='Moyenne' ? 'selected' : '' %>>Moyenne</option>
          <option <%=selectedPriority==='Haute' ? 'selected' : '' %>>Haute</option>
        </select>
      </div>
    </form>


    <ul class="list-group">
      <% todos.forEach(todo=> { %>
        <li class="list-group-item d-flex justify-content-between align-items-start">
          <div>
            <h5>
              <%= todo.task %>
            </h5>
            <p class="mb-1">
              <%= todo.description %>
            </p>
            <span
              class="badge bg-<%= todo.priority === 'Haute' ? 'danger' : todo.priority === 'Moyenne' ? 'warning' : 'secondary' %> me-2">
              <%= todo.priority %>
            </span>
            <span class="badge bg-info text-dark">
              <%= todo.status %>
            </span>
            <% if (todo.dueDate) { %>
              <span class="badge bg-dark ms-2">🗓 <%= todo.dueDate.toISOString().split('T')[0] %></span>
              <% } %>
          </div>
          <div>
            <a class="btn btn-sm btn-outline-primary mb-2" href="/edit/<%= todo._id %>">Modifier</a>
            <a href="/history/<%= todo._id %>" class="btn btn-sm btn-outline-dark">Historique</a>
            <form action="/delete/<%= todo._id %>" method="POST" class="d-inline">
              <button class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
          </div>
        </li>
        <% }) %>
    </ul>
  </div>
</body>

</html>